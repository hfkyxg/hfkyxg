# apathy — environment variables
# Copy to .env and fill in the keys you want to use.

# ─── LLM Providers ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=https://<your-resource>.openai.azure.com/
AZURE_API_VERSION=2024-02-01
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=
TOGETHER_API_KEY=
REPLICATE_API_KEY=
HUGGINGFACE_API_KEY=
OLLAMA_API_BASE=http://localhost:11434

# ─── Search Backends ────────────────────────────────────────────────────────
GOOGLE_CSE_ID=
BRAVE_API_KEY=
SERPER_API_KEY=

# ─── Notifications ──────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Memory / Storage ───────────────────────────────────────────────────────
MEMORY_DB_PATH=

# ─── Runtime Defaults ───────────────────────────────────────────────────────
DEFAULT_MODEL=anthropic/claude-sonnet-4-6
DEFAULT_WORKSPACE=.
MAX_BASH_TIMEOUT=30
DEFAULT_NUM_WORKERS=4
