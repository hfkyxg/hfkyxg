# apathy — environment variables
# Copy to .env and fill in the keys you want to use.

# ─── LLM Providers ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=https://<your-resource>.openai.azure.com/
AZURE_API_VERSION=2024-02-01
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=
TOGETHER_API_KEY=
REPLICATE_API_KEY=
HUGGINGFACE_API_KEY=
OLLAMA_API_BASE=http://localhost:11434

# ─── Search Backends ────────────────────────────────────────────────────────
GOOGLE_CSE_ID=
BRAVE_API_KEY=
SERPER_API_KEY=

# ─── Notifications ──────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Email (email_send tool) ────────────────────────────────────────────────
# Option A — SMTP (Gmail: use an App Password, not your login password):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Option B — Mailgun API:
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ─── Private cloud (cloud_sync / backup-videos) ─────────────────────────────
# No env vars needed — apathy uses the `rclone` binary. Install it and run
# `rclone config` once to connect your own Google Drive / OneDrive / Dropbox /
# MEGA account. Everything uploaded stays private to that account.

# ─── Memory / Storage ───────────────────────────────────────────────────────
MEMORY_DB_PATH=

# ─── Runtime Defaults ───────────────────────────────────────────────────────
DEFAULT_MODEL=anthropic/claude-sonnet-4-6
DEFAULT_WORKSPACE=.
MAX_BASH_TIMEOUT=30
DEFAULT_NUM_WORKERS=4
